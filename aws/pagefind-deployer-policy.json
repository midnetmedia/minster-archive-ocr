{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListPagefindPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::archives.minsterhistoricalsociety.com",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "pagefind/*"
          ]
        }
      }
    },
    {
      "Sid": "WritePagefindOnly",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::archives.minsterhistoricalsociety.com/pagefind/*"
    }
  ]
}
